{
  "cleanUrls": true,
  "functions": {
    "api/ai.js": { "maxDuration": 60 },
    "api/summarize.js": { "maxDuration": 60 },
    "api/pexels.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    
    { "source": "/Apps/:appName/:path*", "destination": "/:appName/:path*" },
    
    { "source": "/", "destination": "/index.html" },
    { "source": "/:name", "destination": "/Apps/:name/main.html" }
  ]
}